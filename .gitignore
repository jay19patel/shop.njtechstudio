# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js (frontend)
.next/
out/
build/

# python / fastAPI (backend)
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.venv/
.pytest_cache/

# misc
.DS_Store
*.pem

